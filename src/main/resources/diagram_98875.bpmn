    <bpmn:userTask id="Activity_0fvl9o8" name="Employee submits:">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="number" label="enter number " type="long" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1pd3prh</bpmn:incoming>
      <bpmn:outgoing>Flow_1rj820o</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_0yjtsxv">
      <bpmn:incoming>Flow_1rj820o</bpmn:incoming>
      <bpmn:outgoing>Auto_approve</bpmn:outgoing>
      <bpmn:outgoing>check_Manager</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1rj820o" sourceRef="Activity_0fvl9o8" targetRef="Gateway_0yjtsxv" />
    <bpmn:sequenceFlow id="Auto_approve" name="Auto aprto" sourceRef="Gateway_0yjtsxv" targetRef="Activity_05ch7uc">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="js">number &lt; 2</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="check_Manager" name="check with Manger" sourceRef="Gateway_0yjtsxv" targetRef="Activity_0276ltl">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="js">number &gt; 2</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:scriptTask id="Activity_05ch7uc" name="Auto_approve" scriptFormat="js">
