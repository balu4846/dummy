    <bpmn:sequenceFlow id="Flow_0jh1yl1" name="check_approved" sourceRef="Gateway_0us90em" targetRef="Activity_04yrsmd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="js">approved == true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:scriptTask id="Activity_04yrsmd" scriptFormat="js">
